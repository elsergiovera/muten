{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "clean",
        "command": "dotnet",
        "type": "shell",
        "args": [
          "clean",
          "${workspaceFolder}/MUTEn.csproj"
        ],
        "problemMatcher": "$msCompile"
      },
      {
        "label": "build",
        "command": "dotnet",
        "type": "shell",
        "args": [
          "build",
          "${workspaceFolder}/MUTEn.csproj"
        ],
        "problemMatcher": "$msCompile"
      },
      {
        "label": "rebuild",
        "dependsOrder": "sequence",
        "dependsOn": ["clean", "build"]
      }
    ]
  }
  